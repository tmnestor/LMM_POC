graph LR
    subgraph pp ["Pipeline: every image visits every GPU"]
        direction LR
        PP_IN["100 images"] --> PP0["GPU 0<br/>Layers 0-7"]
        PP0 -->|"transfer"| PP1["GPU 1<br/>Layers 8-15"]
        PP1 -->|"transfer"| PP2["GPU 2<br/>Layers 16-23"]
        PP2 -->|"transfer"| PP3["GPU 3<br/>Layers 24-31"]
        PP3 --> PP_OUT["100 results"]
    end

    subgraph dp ["Data Parallel: each GPU gets its own image subset"]
        direction LR
        DP_IN["100 images"] --> DP0["GPU 0 — All layers<br/>images 0-24"]
        DP_IN --> DP1["GPU 1 — All layers<br/>images 25-49"]
        DP_IN --> DP2["GPU 2 — All layers<br/>images 50-74"]
        DP_IN --> DP3["GPU 3 — All layers<br/>images 75-99"]
        DP0 --> DP_OUT["100 results"]
        DP1 --> DP_OUT
        DP2 --> DP_OUT
        DP3 --> DP_OUT
    end

    style PP_IN fill:#FFF2CC,stroke:#D6B656,stroke-width:2px,color:#333
    style PP0 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style PP1 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style PP2 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style PP3 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style PP_OUT fill:#FFF2CC,stroke:#D6B656,stroke-width:2px,color:#333
    style DP_IN fill:#DAE8FC,stroke:#6C8EBF,stroke-width:2px,color:#333
    style DP0 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style DP1 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style DP2 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style DP3 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style DP_OUT fill:#DAE8FC,stroke:#6C8EBF,stroke-width:2px,color:#333

    linkStyle 1 stroke:#B85450,stroke-width:2px
    linkStyle 2 stroke:#B85450,stroke-width:2px
    linkStyle 3 stroke:#B85450,stroke-width:2px
