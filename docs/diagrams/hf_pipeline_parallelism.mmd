graph LR
    subgraph load [" "]
        direction TB
        A["Single from_pretrained<br/>device_map = split_model()"]
    end

    subgraph pipeline ["Only 1 GPU active at a time"]
        direction LR
        C["GPU 0<br/>Vision Encoder + MLP1<br/>+ Layers 0-4<br/>(5 LLM layers)"]
        D["GPU 1<br/>Layers 5-14<br/>(10 LLM layers)"]
        E["GPU 2<br/>Layers 15-24<br/>(10 LLM layers)"]
        F["GPU 3<br/>Layers 25-31<br/>(7 LLM layers)"]
        C -->|"hidden state<br/>transfer"| D -->|"hidden state<br/>transfer"| E -->|"hidden state<br/>transfer"| F
    end

    subgraph output [" "]
        direction TB
        G["Single output<br/>1 image at a time"]
    end

    A --> C
    F --> G

    style A fill:#DAE8FC,stroke:#6C8EBF,stroke-width:2px,color:#333
    style C fill:#ECECFF,stroke:#7B68AE,stroke-width:2px,color:#333
    style D fill:#ECECFF,stroke:#7B68AE,stroke-width:2px,color:#333
    style E fill:#ECECFF,stroke:#7B68AE,stroke-width:2px,color:#333
    style F fill:#ECECFF,stroke:#7B68AE,stroke-width:2px,color:#333
    style G fill:#F8CECC,stroke:#B85450,stroke-width:2px,color:#333
    style load fill:none,stroke:none
    style output fill:none,stroke:none

    linkStyle 0 stroke:#B85450,stroke-width:2px
    linkStyle 1 stroke:#B85450,stroke-width:2px
    linkStyle 2 stroke:#B85450,stroke-width:2px
