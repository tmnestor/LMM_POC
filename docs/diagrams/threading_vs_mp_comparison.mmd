graph TB
    subgraph threading ["Multithreading (Chosen)"]
        direction TB
        T1["Single Process<br/>Import once"] --> T2["Shared Address Space"]
        T2 --> T3["Thread 0 → GPU 0<br/>Own model copy"]
        T2 --> T4["Thread 1 → GPU 1<br/>Own model copy"]
        T2 --> T5["Thread 2 → GPU 2<br/>Own model copy"]
        T2 --> T6["Thread 3 → GPU 3<br/>Own model copy"]
        T3 --> T7["Direct Result Access<br/>No Serialisation"]
        T4 --> T7
        T5 --> T7
        T6 --> T7
    end

    subgraph multiprocessing ["Multiprocessing"]
        direction TB
        M1["Fork/Spawn<br/>N Processes"] --> M2["Separate Memory Spaces"]
        M2 --> M3["Process 0 → GPU 0<br/>Own model copy<br/>Re-import torch, transformers"]
        M2 --> M4["Process 1 → GPU 1<br/>Own model copy<br/>Re-import torch, transformers"]
        M2 --> M5["Process 2 → GPU 2<br/>Own model copy<br/>Re-import torch, transformers"]
        M2 --> M6["Process 3 → GPU 3<br/>Own model copy<br/>Re-import torch, transformers"]
        M3 --> M7["Pickle → IPC Queue<br/>Deserialise Results"]
        M4 --> M7
        M5 --> M7
        M6 --> M7
    end

    style T1 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style T2 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style T3 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style T4 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style T5 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style T6 fill:#ECECFF,stroke:#7B68AE,stroke-width:1px,color:#333
    style T7 fill:#D5E8D4,stroke:#82B366,stroke-width:2px,color:#333
    style M1 fill:#F8CECC,stroke:#B85450,stroke-width:2px,color:#333
    style M2 fill:#F8CECC,stroke:#B85450,stroke-width:2px,color:#333
    style M3 fill:#FFF2CC,stroke:#D6B656,stroke-width:1px,color:#333
    style M4 fill:#FFF2CC,stroke:#D6B656,stroke-width:1px,color:#333
    style M5 fill:#FFF2CC,stroke:#D6B656,stroke-width:1px,color:#333
    style M6 fill:#FFF2CC,stroke:#D6B656,stroke-width:1px,color:#333
    style M7 fill:#F8CECC,stroke:#B85450,stroke-width:2px,color:#333
